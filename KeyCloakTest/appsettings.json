{
  "Auth": {
    "Authority": "http://localhost:8080/realms/auth-demo",
    "ValidAudiences": [
      "auth-demo-api"
    ],
    "ApiClientId": "auth-demo-api",
    "SwaggerClientId": "auth-demo-swagger",
    "RequireHttpsMetadata": false
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5083",
      "http://localhost:8080"
    ]
  },
  "RateLimiting": {
    "PermitLimit": 10,
    "WindowSeconds": 10,
    "QueueLimit": 0
  },
  "UseHttpsRedirection": false,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
